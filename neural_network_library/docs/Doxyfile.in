PROJECT_NAME           = "NeuralNetCpp"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
OUTPUT_DIRECTORY       = "@DOXYGEN_OUTPUT_DIRECTORY@"
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = NO
OUTPUT_LANGUAGE        = English
USE_MDFILE_AS_MAINPAGE = "@DOXYGEN_MAINPAGE@"

INPUT                  = @DOXYGEN_INPUT@
FILE_PATTERNS          = *.hpp *.cpp *.md
RECURSIVE              = YES
EXCLUDE                = "@CMAKE_CURRENT_SOURCE_DIR@/build" "@CMAKE_CURRENT_SOURCE_DIR@/build_comment_check" "@CMAKE_CURRENT_SOURCE_DIR@/build_docs"

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = YES
HTML_DYNAMIC_SECTIONS  = YES
HTML_OUTPUT            = html

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

INLINE_SOURCES         = NO
SOURCE_BROWSER         = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
STRIP_FROM_PATH        = "@CMAKE_CURRENT_SOURCE_DIR@"